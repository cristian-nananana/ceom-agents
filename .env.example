# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# GA4 Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — NEVER expose to browser! Server-side only
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sekrebot.cl
NEXT_PUBLIC_WA_NUMBER=56963926061

# ─── Resend (email de confirmación) ───────────────────────────────────────────
# API key de resend.com — si no está configurado, se loguea el token (no se envía email)
RESEND_API_KEY=
